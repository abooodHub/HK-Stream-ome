<?xml version="1.0" encoding="UTF-8" ?>
<!--
  قالب إعداد OvenMediaEngine لـ HK-Stream-ome.
  يستبدل سكربت install.sh العلامات النائبة: __OME_API_TOKEN__ ، __PUBLIC_IP__ ، __DISTRIBUTION__
-->
<Server version="8">
	<Name>OvenMediaEngine</Name>
	<Type>origin</Type>
	<IP>*</IP>
	<PrivacyProtection>true</PrivacyProtection>
	<StunServer>stun.ovenmediaengine.com:13478</StunServer>

	<Modules>
		<HTTP2>
			<Enable>true</Enable>
		</HTTP2>
		<LLHLS>
			<Enable>true</Enable>
		</LLHLS>
		<P2P>
			<Enable>false</Enable>
		</P2P>
	</Modules>

	<Bind>
		<Managers>
			<API>
				<Port>8081</Port>
				<WorkerCount>1</WorkerCount>
			</API>
		</Managers>
		<Providers>
			<RTMP>
				<Port>1935</Port>
				<WorkerCount>1</WorkerCount>
			</RTMP>
		</Providers>
		<Publishers>
			<LLHLS>
				<Port>8080</Port>
				<WorkerCount>1</WorkerCount>
			</LLHLS>
			<WebRTC>
				<Signalling>
					<Port>3333</Port>
					<WorkerCount>1</WorkerCount>
				</Signalling>
				<IceCandidates>
					<IceCandidate>__PUBLIC_IP__:10000-10099/udp</IceCandidate>
					<TcpRelay>__PUBLIC_IP__:3478</TcpRelay>
					<TcpForce>false</TcpForce>
					<TcpRelayWorkerCount>1</TcpRelayWorkerCount>
				</IceCandidates>
			</WebRTC>
		</Publishers>
	</Bind>

	<!-- Managers configuration for REST API -->
	<Managers>
		<API>
			<AccessToken>__OME_API_TOKEN__</AccessToken>
		</API>
	</Managers>

	<Defaults>
		<CrossDomains>
			<Url>*</Url>
		</CrossDomains>
	</Defaults>

	<VirtualHosts>
		<VirtualHost>
			<Name>default</Name>
			<Distribution>__DISTRIBUTION__</Distribution>
			<Host>
				<Names>
					<Name>*</Name>
				</Names>
			</Host>

			<!-- Admission Webhooks for Security (مفتاح البث + حماية) -->
			<AdmissionWebhooks>
				<ControlServerUrl>http://127.0.0.1:9999/api/ome/webhook</ControlServerUrl>
				<Timeout>3000</Timeout>
			</AdmissionWebhooks>

			<Applications>
				<Application>
					<Name>app</Name>
					<Type>live</Type>
					<OutputProfiles>
						<OutputProfile>
							<Name>default_profile</Name>
							<OutputStreamName>stream</OutputStreamName>

							<Playlist>
								<Name>default</Name>
								<FileName>master</FileName>
								<Options>
									<WebRtcAutoAbr>true</WebRtcAutoAbr>
									<HLSChunklistPathDepth>0</HLSChunklistPathDepth>
									<EnableTsPackaging>true</EnableTsPackaging>
								</Options>
								<RenditionTemplate>
									<Name>${Height}p</Name>
									<VideoTemplate>
										<EncodingType>all</EncodingType>
									</VideoTemplate>
									<AudioTemplate>
										<EncodingType>all</EncodingType>
									</AudioTemplate>
								</RenditionTemplate>
							</Playlist>

							<Encodes>
								<!-- Source (Bypass) — تمرير الجودة الأصلية فقط، بدون ترميز (يلغي ضغط المعالج) -->
								<Video>
									<Name>bypass_video</Name>
									<Bypass>true</Bypass>
								</Video>
								<!-- Audio configuration -->
								<Audio>
									<Name>aac_audio</Name>
									<Codec>aac</Codec>
									<Bitrate>192000</Bitrate>
									<Samplerate>48000</Samplerate>
									<Channel>2</Channel>
									<BypassIfMatch>
										<Codec>eq</Codec>
									</BypassIfMatch>
								</Audio>
								<Audio>
									<Name>opus_audio</Name>
									<Codec>opus</Codec>
									<Bitrate>128000</Bitrate>
									<Samplerate>48000</Samplerate>
									<Channel>2</Channel>
									<BypassIfMatch>
										<Codec>eq</Codec>
									</BypassIfMatch>
								</Audio>
							</Encodes>
						</OutputProfile>
					</OutputProfiles>
					<Providers>
						<WebRTC>
							<Timeout>30000</Timeout>
						</WebRTC>
						<RTMP />
					</Providers>
					<Publishers>
						<AppWorkerCount>4</AppWorkerCount>
						<StreamWorkerCount>4</StreamWorkerCount>
						<WebRTC>
							<Timeout>30000</Timeout>
							<Rtx>true</Rtx>
							<Ulpfec>true</Ulpfec>
							<JitterBuffer>true</JitterBuffer>
							<CreateDefaultPlaylist>true</CreateDefaultPlaylist>
						</WebRTC>
						<LLHLS>
							<OriginMode>true</OriginMode>
							<ChunkDuration>0.5</ChunkDuration>
							<PartHoldBack>1.5</PartHoldBack>
							<SegmentDuration>6</SegmentDuration>
							<SegmentCount>10</SegmentCount>
							<CreateDefaultPlaylist>true</CreateDefaultPlaylist>
						</LLHLS>
						<HLS>
							<SegmentCount>4</SegmentCount>
							<SegmentDuration>4</SegmentDuration>
							<CreateDefaultPlaylist>true</CreateDefaultPlaylist>
						</HLS>
					</Publishers>
				</Application>
			</Applications>
		</VirtualHost>
	</VirtualHosts>
</Server>
