# انسخ هذا الملف إلى .env واملأ القيم الحقيقية (لا تَرفع .env إلى Git)
# cp .env.example .env

# مفتاح football-data.org API — احصل عليه من https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_football_data_api_key_here

# توكن OvenMediaEngine API — يجب أن يطابق <AccessToken> في Server.xml
# ولّد توكن قوي: openssl rand -hex 32
OME_API_TOKEN=your_strong_ome_api_token_here

# النطاق المسموح به في CORS (يجب أن يطابق دومينك الفعلي مع https://)
ALLOWED_ORIGIN=https://your-domain.com
